{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "ES2020",
		"outDir": "dist",
		"declaration": true,
		"noEmit": false,
		"esModuleInterop": true,
		"verbatimModuleSyntax": false,
		"erasableSyntaxOnly": false,
		"types": ["node", "vitest/globals"]
	},
	"include": ["**/*"],
	"exclude": ["node_modules", "dist"]
}
